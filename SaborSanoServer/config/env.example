# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=paloma_db
DB_USER=root
DB_PASSWORD=

# Stripe (Payment Intents + Webhooks)
# Usa tu secret key (test o live) desde Stripe Dashboard
STRIPE_SECRET_KEY=
# Firma del endpoint webhook (Stripe CLI o Dashboard)
STRIPE_WEBHOOK_SECRET=

# Cron diario (1:00 AM): pedidos y envíos
CRON_TIMEZONE=Europe/Madrid
ENABLE_DAILY_STATUS_CRON=true
